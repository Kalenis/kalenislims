<?xml version="1.0"?>
<data>
    <xpath expr="/form/label[@name='product_type']" position="before">
        <label name="quality"/>
        <field name="quality"/>
        <newline/>
    </xpath>
    <xpath expr="/form/label[@name='detection_limit']" position="before">
        <group id="limits" colspan="4" col="6">
            <label name="quality_min"/>
            <field name="quality_min"/>
            <label name="quality_max"/>
            <field name="quality_max"/>
            <label name="valid_value"/>
            <field name="valid_value"/>
        </group>
        <separator id="specification" string="Specification" colspan="4"/>
        <field name="specification" colspan="4"/>
    </xpath>
</data>
